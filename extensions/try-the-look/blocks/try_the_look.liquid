<!-- Try the Look Button and Popup - Updated UI -->
{% assign current_product = block.settings.product %}

<!-- Main Try the Look Button -->
<div class="try-the-look-container">
  <button 
    class="try-the-look-btn" 
    onclick="openTryTheLookPopup()"
    type="button"
  >
    <div class="btn-content">
      <span class="btn-main-text">See Before You Buy</span>
      <span class="btn-subtitle">AI Preview, No Camera</span>
    </div>
  </button>
</div>

<!-- Popup Modal -->
<div id="try-the-look-popup" class="popup-overlay" onclick="closeTryTheLookPopup()">
  <div class="popup-content" onclick="event.stopPropagation()">
    
    <!-- Popup Header -->
    <div class="popup-header">
      <h2>{{ 'try_the_look.popup_title' | t }}</h2>
      <button class="close-btn" onclick="closeTryTheLookPopup()" aria-label="Close">&times;</button>
    </div>
    
    <!-- Product Information -->
    <div class="product-info">
      <div class="product-details">
        {% if current_product.featured_image %}
          <img 
            src="{{ current_product.featured_image | image_url: width: 120, height: 120 }}" 
            alt="{{ current_product.title }}"
            class="product-image"
            width="120"
            height="120"
          >
        {% endif %}
        <div class="product-text">
          <h3>{{ current_product.title }}</h3>
          <p class="product-subtitle">Preview how it looks on you</p>
        </div>
      </div>
    </div>
    
    <!-- Upload Section -->
    <div class="upload-section" id="upload-section">
      
      <input 
        type="file" 
        id="user-image-input" 
        accept="image/*"
        style="display: none;"
        onchange="handleImageSelect(event)"
      >
      
      <!-- Upload Area -->
      <div id="upload-area" class="upload-area" onclick="document.getElementById('user-image-input').click()">
        <div class="upload-icon">📸</div>
        <h4>{{ 'try_the_look.upload_title' | t }}</h4>
        <p>{{ 'try_the_look.upload_subtitle' | t }}</p>
 <button 
    class="upload-photo-btn-2" 
  >
    Upload a Photo
  </button>

        <p class="no-camera-text">No camera access required</p>
      </div>
      
      <!-- Image Preview -->
      <div id="image-preview-container" class="preview-container" style="display: none;">
       <div class="preview-wrapper">
  <img id="image-preview" src="" alt="Preview" class="preview-image">
  
  <!-- Loading Overlay with Progress Bar -->
  <div id="loading-overlay" class="loading-overlay" style="display: none;">
    <p class="progress-percentage" id="progress-percentage">0%</p>
    <div class="progress-bar-container">
      <div class="progress-bar-fill" id="progress-bar-fill"></div>
    </div>
  </div>
  
  <button 
    class="remove-image-btn" 
    onclick="removeImage(event)"
    type="button"
    aria-label="Remove image"
  >
    ✕
  </button>
</div>

      
      
        <p class="preview-filename" id="preview-filename"></p>
      </div>
      
      <!-- Generate Button -->
      <button 
        id="submit-btn" 
        class="submit-btn" 
        onclick="submitTryTheLook()"
        type="button"
        disabled
      >
        <span class="btn-text">{{ 'try_the_look.submit_button' | t }}</span>
        <span class="btn-icon">→</span>
      </button>
      
      <!-- Status Message -->
      <div id="status-message" class="status-message"></div>
    </div>
    
    <!-- Result Section (Hidden by default) -->
    <div id="result-section" class="result-section" style="display: none;">
  
  <div class="result-image-wrapper">
    
    <span class="preview-badge">Your Preview</span>
    
    <img id="generated-image" src="" alt="Generated result" class="generated-image">
    
    <div class="overlay-actions">
      <button 
        id="download-btn" 
        class="overlay-icon-btn"
        onclick="downloadGeneratedImage()"
        type="button"
        title="Download Preview"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
      </button>
      
      <button 
        id="share-btn" 
        class="overlay-icon-btn"
        onclick="shareGeneratedImage()"
        type="button"
        title="Share Preview"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
        </svg>
      </button>
    </div>
  </div>
  
  <button 
    id="add-to-cart-btn" 
    class="add-to-cart-btn"
    onclick="handleAddToCart()"
    type="button"
  >
    Add to Cart
  </button>
</div>
    
  </div>
</div>

