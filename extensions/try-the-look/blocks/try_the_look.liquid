<!-- JavaScript -->
<script>
  let selectedImageFile = null;
  let shopSettings = null; // Store fetched settings
  
  // Generate UUID v4 for session ID
  function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0;
      const v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }
  
  // Get or create session ID
  function getSessionId() {
    let sessionId = localStorage.getItem('sbb_session_id');
    if (!sessionId) {
      sessionId = generateUUID();
      localStorage.setItem('sbb_session_id', sessionId);
      console.log('🆔 New session ID created:', sessionId);
    } else {
      console.log('🆔 Existing session ID:', sessionId);
    }
    return sessionId;
  }
  
  // Fetch and apply shop settings
  async function fetchAndApplySettings() {
    const shopDomain = window.Shopify?.shop || 'see-before-buy-ai.myshopify.com';
    
    try {
      console.log('⚙️  Fetching shop settings...');
      const response = await fetch(`http://localhost:5000/api/settings/${shopDomain}`);
      const data = await response.json();
      
      if (data.success && data.settings) {
        shopSettings = data.settings;
        console.log('✅ Settings loaded:', shopSettings);
        applySettings(shopSettings);
      } else {
        console.log('⚠️  No custom settings found, using defaults');
      }
    } catch (error) {
      console.error('❌ Error fetching settings:', error);
      console.log('⚠️  Using default styles');
    } finally {
      // Remove loading state - show button
      const button = document.querySelector('.try-the-look-btn');
      if (button) {
        button.style.opacity = '1';
        button.style.visibility = 'visible';
      }
    }
  }
  
  // Apply settings to button and popup
  function applySettings(settings) {
    if (!settings) return;
    
    // Apply button settings
    const button = document.querySelector('.try-the-look-btn');
    if (button && settings.button) {
      const btnContent = button.querySelector('.btn-content');
      const btnMainText = button.querySelector('.btn-main-text');
      
      // Update button text
      if (btnMainText && settings.button.text) {
        btnMainText.textContent = settings.button.text;
      }
      
      // Apply button styles
      button.style.background = `linear-gradient(135deg, ${settings.button.bg_color} 0%, ${adjustColor(settings.button.bg_color, -20)} 100%)`;
      button.style.color = settings.button.text_color;
      button.style.borderRadius = `${settings.button.border_radius}px`;
      
      // Apply button size
      if (settings.button.size === 'small') {
        button.style.padding = '12px 20px';
        button.style.fontSize = '14px';
        button.style.minHeight = '50px';
      } else if (settings.button.size === 'large') {
        button.style.padding = '20px 28px';
        button.style.fontSize = '18px';
        button.style.minHeight = '70px';
      }
      // medium is default, no changes needed
      
      console.log('✅ Button styles applied');
    }
    
    // Apply popup settings
    const popupHeader = document.querySelector('.popup-header h2');
    const uploadBtn = document.querySelector('.upload-photo-btn-2');
    const submitBtn = document.getElementById('submit-btn');
    const popupContent = document.querySelector('.popup-content');
    
    if (settings.popup) {
      // Update popup title
      if (popupHeader && settings.popup.title) {
        popupHeader.textContent = settings.popup.title;
      }
      
      // Update upload button text
      if (uploadBtn && settings.popup.upload_button_text) {
        uploadBtn.textContent = settings.popup.upload_button_text;
      }
      
      // Update generate button text
      if (submitBtn && settings.popup.generate_button_text) {
        const btnText = submitBtn.querySelector('.btn-text');
        if (btnText) {
          btnText.textContent = settings.popup.generate_button_text;
        }
      }
      
      // Apply popup background and text color
      if (popupContent) {
        popupContent.style.backgroundColor = settings.popup.bg_color;
        popupContent.style.color = settings.popup.text_color;
        popupContent.style.borderRadius = `${settings.popup.border_radius}px`;
      }
      
      console.log('✅ Popup styles applied');
    }
    
    // Apply add_to_cart_button settings
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    if (addToCartBtn && settings.add_to_cart_button) {
      // Update button text
      if (settings.add_to_cart_button.text) {
        addToCartBtn.textContent = settings.add_to_cart_button.text;
      }
      
      // Apply button styles
      addToCartBtn.style.background = `linear-gradient(135deg, ${settings.add_to_cart_button.bg_color} 0%, ${adjustColor(settings.add_to_cart_button.bg_color, -20)} 100%)`;
      addToCartBtn.style.color = settings.add_to_cart_button.text_color;
      addToCartBtn.style.borderRadius = `${settings.add_to_cart_button.border_radius}px`;
      
      // Apply button size
      if (settings.add_to_cart_button.size === 'small') {
        addToCartBtn.style.padding = '12px 20px';
        addToCartBtn.style.fontSize = '14px';
      } else if (settings.add_to_cart_button.size === 'large') {
        addToCartBtn.style.padding = '20px 32px';
        addToCartBtn.style.fontSize = '18px';
      }
      // medium is default (16px 24px)
      
      console.log('✅ Add to Cart button styles applied');
    }
  }
  
  // Helper function to darken/lighten color for gradient
  function adjustColor(color, percent) {
    const num = parseInt(color.replace('#', ''), 16);
    const amt = Math.round(2.55 * percent);
    const R = (num >> 16) + amt;
    const G = (num >> 8 & 0x00FF) + amt;
    const B = (num & 0x0000FF) + amt;
    return '#' + (0x1000000 + (R < 255 ? R < 1 ? 0 : R : 255) * 0x10000 +
      (G < 255 ? G < 1 ? 0 : G : 255) * 0x100 +
      (B < 255 ? B < 1 ? 0 : B : 255))
      .toString(16).slice(1);
  }
  
  // Ensure popup is hidden on page load and fetch settings
  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('try-the-look-popup');
    if (popup) {
      popup.classList.remove('active');
      popup.style.display = 'none';
    }
    
    // Initialize session ID on page load
    getSessionId();
    
    // Fetch and apply settings immediately
    fetchAndApplySettings();
  });
  
  // Also fetch settings as soon as script loads (before DOMContentLoaded)
  (function() {
    if (document.readyState === 'loading') {
      // Wait for DOM
      document.addEventListener('DOMContentLoaded', function() {
        fetchAndApplySettings();
      });
    } else {
      // DOM already loaded
      fetchAndApplySettings();
    }
  })();
  
  function openTryTheLookPopup() {
    const popup = document.getElementById('try-the-look-popup');
    popup.style.display = 'block';
    popup.classList.add('active');
    document.body.style.overflow = 'hidden';
    resetForm();
  }
  
  function closeTryTheLookPopup() {
    const popup = document.getElementById('try-the-look-popup');
    popup.classList.remove('active');
    popup.style.display = 'none';
    document.body.style.overflow = '';
    resetForm();
  }
  
  function handleImageSelect(event) {
    const file = event.target.files[0];
    
    if (file && file.type.startsWith('image/')) {
      selectedImageFile = file;
      
      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById('image-preview');
        const container = document.getElementById('image-preview-container');
        const filename = document.getElementById('preview-filename');
        const uploadArea = document.getElementById('upload-area');
        
        preview.src = e.target.result;
        filename.textContent = file.name;
        container.style.display = 'block';
        uploadArea.style.display = 'none';
        
        document.getElementById('submit-btn').disabled = false;
      };
      reader.readAsDataURL(file);
    }
  }
  
 function removeImage(event) {
  if (event) event.stopPropagation();
  
  selectedImageFile = null;
  document.getElementById('image-preview-container').style.display = 'none';
  document.getElementById('image-preview').src = '';
  document.getElementById('preview-filename').textContent = '';
  document.getElementById('user-image-input').value = '';
  document.getElementById('upload-area').style.display = 'block';
  document.getElementById('submit-btn').disabled = true;
  document.getElementById('loading-overlay').style.display = 'none';
  
  // Reset progress bar
  const progressBarFill = document.getElementById('progress-bar-fill');
  const progressPercentage = document.getElementById('progress-percentage');
  if (progressBarFill) progressBarFill.style.width = '0%';
  if (progressPercentage) progressPercentage.textContent = '0%';
  
  hideStatus();
}

  
async function submitTryTheLook() {
  if (!selectedImageFile) {
    showStatus('Please select an image first', 'error');
    return;
  }
  
  // Show loading overlay on the uploaded image
  const loadingOverlay = document.getElementById('loading-overlay');
  const submitBtn = document.getElementById('submit-btn');
  const removeBtn = document.querySelector('.remove-image-btn');
  const progressBarFill = document.getElementById('progress-bar-fill');
  const progressPercentage = document.getElementById('progress-percentage');
  
  loadingOverlay.style.display = 'flex';
  submitBtn.disabled = true;
  submitBtn.style.display = 'none';
  if (removeBtn) removeBtn.style.display = 'none';
  
  // Animate progress bar
  let progress = 0;
  const progressInterval = setInterval(() => {
    if (progress < 90) {
      progress += Math.random() * 15;
      if (progress > 90) progress = 90;
      progressBarFill.style.width = progress + '%';
      progressPercentage.textContent = Math.round(progress) + '%';
    }
  }, 500);
  
  try {
    const productTitle = document.querySelector('.product-text h3')?.textContent || 'Unknown Product';
    const productImageUrl = document.querySelector('.product-image')?.src || '';
    const shopDomain = window.Shopify?.shop || 'see-before-buy-ai.myshopify.com';
    
    // Get session ID
    const sessionId = getSessionId();
    
    const formData = new FormData();
    formData.append('userImage', selectedImageFile);
    formData.append('shop_domain', shopDomain);
    formData.append('product_name', productTitle);
    formData.append('session_id', sessionId);  // Add session ID
    if (productImageUrl) {
      formData.append('product_image_url', productImageUrl);
    }
    
    const response = await fetch('http://localhost:5000/api/generate-image', {
      method: 'POST',
      body: formData
    });
    
    const data = await response.json();
    
    // Complete progress bar
    clearInterval(progressInterval);
    progressBarFill.style.width = '100%';
    progressPercentage.textContent = '100%';
    
    if (data.success) {
      // Wait a moment to show 100% completion, then show image immediately
      setTimeout(() => {
        // Hide loading overlay and upload section
        loadingOverlay.style.display = 'none';
        document.getElementById('upload-section').style.display = 'none';
        
        // Show generated image immediately (no delay)
        const resultSection = document.getElementById('result-section');
        const generatedImage = document.getElementById('generated-image');
        
        generatedImage.src = data.generated_image_url;
        resultSection.style.display = 'block';
        resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 300);
      
    } else if (data.error === 'limit_reached') {
      loadingOverlay.style.display = 'none';
      submitBtn.style.display = 'flex';
      if (removeBtn) removeBtn.style.display = 'flex';
      submitBtn.disabled = false;
      progressBarFill.style.width = '0%';
      progressPercentage.textContent = '0%';
      showStatus('⚠️ Free limit reached (15 images). Please contact store owner to upgrade.', 'error');
      
    } else {
      loadingOverlay.style.display = 'none';
      submitBtn.style.display = 'flex';
      if (removeBtn) removeBtn.style.display = 'flex';
      submitBtn.disabled = false;
      progressBarFill.style.width = '0%';
      progressPercentage.textContent = '0%';
      showStatus('Error: ' + data.message, 'error');
    }
    
  } catch (error) {
    console.error('Generation error:', error);
    clearInterval(progressInterval);
    loadingOverlay.style.display = 'none';
    submitBtn.style.display = 'flex';
    if (removeBtn) removeBtn.style.display = 'flex';
    submitBtn.disabled = false;
    progressBarFill.style.width = '0%';
    progressPercentage.textContent = '0%';
    showStatus('Failed to generate image. Please try again.', 'error');
  }
}

  
  function showStatus(message, type) {
    const statusDiv = document.getElementById('status-message');
    statusDiv.textContent = message;
    statusDiv.className = 'status-message ' + type;
  }
  
  function hideStatus() {
    const statusDiv = document.getElementById('status-message');
    statusDiv.style.display = 'none';
    statusDiv.className = 'status-message';
  }
  
  /*
  function displayGeneratedImage(imageUrl) {
    const resultSection = document.getElementById('result-section');
    const generatedImage = document.getElementById('generated-image');
    
    generatedImage.src = imageUrl;
    generatedImage.onload = function() {
      resultSection.style.display = 'block';
      resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };
  }
  */
  
  async function downloadGeneratedImage() {
    const generatedImage = document.getElementById('generated-image');
    const imageUrl = generatedImage.src;
    
    try {
      const response = await fetch(imageUrl);
      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'see-before-buy-preview.png';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      window.URL.revokeObjectURL(url);
    } catch (error) {
      console.error('Download error:', error);
      alert('Unable to download image. Please try right-clicking and saving the image.');
    }
  }
  
  async function shareGeneratedImage() {
    const generatedImage = document.getElementById('generated-image');
    const imageUrl = generatedImage.src;
    
    // Check if Web Share API is supported
    if (navigator.share) {
      try {
        await navigator.share({
          title: 'See Before You Buy - AI Preview',
          text: 'Check out how this looks on me!',
          url: imageUrl
        });
      } catch (error) {
        if (error.name !== 'AbortError') {
          console.error('Share error:', error);
          copyToClipboard(imageUrl);
        }
      }
    } else {
      // Fallback: Copy link to clipboard
      copyToClipboard(imageUrl);
    }
  }
  
  function copyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    try {
      document.execCommand('copy');
      alert('Image link copied to clipboard!');
    } catch (error) {
      console.error('Copy error:', error);
      alert('Unable to copy link. URL: ' + text);
    }
    document.body.removeChild(textarea);
  }
  
  async function handleAddToCart() {
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    const originalText = addToCartBtn.textContent;
    addToCartBtn.disabled = true;
    addToCartBtn.textContent = 'Adding...';
    
    try {
      const variantId = getProductVariantId();
      
      if (!variantId) {
        showStatus('Error: Could not add to cart', 'error');
        addToCartBtn.disabled = false;
        addToCartBtn.textContent = originalText;
        return;
      }
      
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1,
          properties: {
            '_sbb_try_on': 'true',
            '_sbb_session_id': getSessionId()
          }
        })
      });
      
      if (!response.ok) throw new Error('Cart API error');
      
      addToCartBtn.textContent = '✓ Added';
      
      // Track add to cart event
      const productTitle = document.querySelector('.product-text h3')?.textContent || 'Unknown Product';
      const shopDomain = window.Shopify?.shop || 'see-before-buy-ai.myshopify.com';
      
      try {
        await fetch('http://localhost:5000/api/track-usage', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            shop_domain: shopDomain,
            event_type: 'add_to_cart',
            product_name: productTitle
          })
        });
        console.log('✅ Add to cart event tracked');
      } catch (trackError) {
        console.error('❌ Failed to track add to cart:', trackError);
        // Don't block the user flow if tracking fails
      }
      
      setTimeout(() => {
        closeTryTheLookPopup();
        window.location.href = '/cart';
      }, 800);
      
    } catch (error) {
      showStatus('Error adding to cart. Please try again.', 'error');
      addToCartBtn.textContent = originalText;
      addToCartBtn.disabled = false;
    }
  }
  
  function getProductVariantId() {
    const variantInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
    if (variantInput) return variantInput.value;
    
    const variantSelect = document.querySelector('select[name="id"]');
    if (variantSelect) return variantSelect.value;
    
    if (window.ShopifyAnalytics?.meta?.product?.variants?.[0]?.id) {
      return window.ShopifyAnalytics.meta.product.variants[0].id;
    }
    
    return null;
  }
  
  function resetForm() {
    removeImage();
    hideStatus();
    document.getElementById('result-section').style.display = 'none';
    document.getElementById('upload-section').style.display = 'block';
    document.getElementById('submit-btn').style.display = 'flex';
  }
  
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      closeTryTheLookPopup();
    }
  });
</script>

